{
  "name": "manhattan-ui-inbound",
  "version": "1.0.0",
  "description": "Playwright Cucumber BDD tests for Manhattan UI - Warehouse Management Inbound Purchase Orders",
  "main": "index.js",
 "scripts": {
  "test": "playwright test --project=firefox",
  "test:bdd": "cucumber-js features --require features/step_definitions",
  "test:codegen": "playwright codegen https://krogs.sce.manh.com/udc/landing",
  "test:debug": "playwright test --debug --project=firefox",
  "test:ui": "playwright test --ui",
  "report": "node generate-report.js"
},
  "keywords": ["playwright", "cucumber", "bdd", "e2e", "testing"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^9.5.1",
    "@cucumber/pretty-formatter": "^1.0.1",
    "@playwright/test": "^1.40.1",
    "@types/node": "^20.10.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}